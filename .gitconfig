[include]
  path = ~/.gitconfig.local

[pull]
  rebase = true

[core]
  pager = delta --dark

[interactive]
  diffFilter = delta --color-only

[alias]
  lg = log --oneline --graph --decorate --all
  s = status -sb
  a = add -p
  cm = commit -m
  co = checkout
  br = branch
  pl = pull
  ps = push

[column]
  ui = auto

[branch]
  sort = committerdate

[tag]
  sort = version:refname
  gpgsign = true

[commit]
  gpgsign = true

[gpg]
  format = ssh

# user.name, user.email, user.signingkey live in ~/.gitconfig.local
# (device-specific — see scripts/setup/git-ssh.sh).

[init]
  defaultBranch = main

[diff]
  algorithm = histogram

