[include]
  path = ~/.gitconfig.local

[pull]
  rebase = true

[core]
  pager = delta --dark

[interactive]
  diffFilter = delta --color-only

[alias]
  lg = log --oneline --graph --decorate --all
  s = status -sb
  a = add -p
  cm = commit -m
  co = checkout
  br = branch
  pl = pull
  ps = push

[column]
  ui = auto

[branch]
  sort = committerdate

[tag]
  sort = version:refname
  gpgsign = true

[commit]
  gpgsign = true

[gpg]
  format = ssh

[user]
  signingkey = ~/.ssh/id_ed25519.pub

[init]
  defaultBranch = main

[diff]
  algorithm = histogram

