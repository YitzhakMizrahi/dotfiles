#!/usr/bin/env bash
set -euo pipefail

source "$HOME/.dotfiles/scripts/lib/paths.sh"

case "${1:-}" in
  test)
    shift
    distro="ubuntu"
    interactive=0
    while [[ $# -gt 0 ]]; do
      case "$1" in
        ubuntu|fedora)    distro="$1" ;;
        -i|--interactive) interactive=1 ;;
        *) echo "Unknown test arg: $1" >&2; exit 1 ;;
      esac
      shift
    done

    dockerfile="$DOTFILES_DIR/Dockerfile.test"
    [[ "$distro" == "fedora" ]] && dockerfile="$DOTFILES_DIR/Dockerfile.fedora.test"

    if [[ "$interactive" -eq 1 ]]; then
      echo "Building interactive test image ($distro)..."
      docker build --network host -f "$dockerfile" --target ready -t "dotfiles-$distro-ready" "$DOTFILES_DIR"
      echo
      docker run -it --network host -e DOTFILES_FORCE_FONTS=1 "dotfiles-$distro-ready" bash .dotfiles/scripts/install.sh
    else
      echo "Building dotfiles CI test image ($distro)..."
      docker build --network host -f "$dockerfile" -t "dotfiles-$distro-test" "$DOTFILES_DIR"
    fi
    ;;
  update)
    source "$DOTFILES_DIR/scripts/lib/ui.sh"
    ui_log_init

    banner "Dotfiles Update" "$(hostname) · $(date +%Y-%m-%d)"

    step "Pull latest changes" git -C "$DOTFILES_DIR" pull --rebase --autostash

    if command -v brew &>/dev/null; then
      step "Homebrew update" brew update

      if [[ -n "$(brew outdated --quiet 2>/dev/null)" ]]; then
        step "Brew upgrade" brew upgrade
      else
        ui_success "All packages up to date"
      fi

      if ! brew bundle check --file="$DOTFILES_DIR/Brewfile" &>/dev/null; then
        step "Install missing packages" brew bundle --file="$DOTFILES_DIR/Brewfile"
      else
        ui_success "All Brewfile packages installed"
      fi

      step "Brew cleanup" brew cleanup -s
    fi

    if command -v mise &>/dev/null; then
      step "Install runtimes (mise)" mise install --yes

      if [[ -n "$(mise outdated 2>/dev/null)" ]]; then
        step "Upgrade runtimes (mise)" mise upgrade --yes
      else
        ui_success "All runtimes up to date"
      fi
    fi

    step "Re-link symlinks" bash "$DOTFILES_DIR/scripts/setup/symlinks.sh"

    echo
    ui_success "Dotfiles updated"
    ;;
  install)
    bash "$DOTFILES_DIR/scripts/install.sh"
    ;;
  doctor)
    bash "$DOTFILES_DIR/scripts/doctor.sh"
    ;;
  edit)
    cd "$DOTFILES_DIR" && ${EDITOR:-vim} .
    ;;
  *)
    echo "Usage: dotfiles {install|update|doctor|test|edit}"
    echo
    echo "  install                 Run full installer (packages, runtimes, shell, git)"
    echo "  update                  Pull latest, upgrade tools and runtimes, re-link"
    echo "  doctor                  Run post-install validation checks"
    echo "  test [ubuntu|fedora]    Build and run Docker CI test (default: ubuntu)"
    echo "  test [distro] -i        Build and launch interactive container"
    echo "  edit                    Open dotfiles directory in \$EDITOR"
    exit 1
    ;;
esac
