#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$HOME/.dotfiles"

case "${1:-}" in
  test)
    if [[ "${2:-}" == "-i" || "${2:-}" == "--interactive" ]]; then
      echo "Building interactive test image..."
      docker build --network host -f "$DOTFILES_DIR/Dockerfile.test" --target ready -t dotfiles-ready "$DOTFILES_DIR"
      echo
      docker run -it --network host -e DOTFILES_FORCE_FONTS=1 dotfiles-ready bash .dotfiles/scripts/install.sh
    else
      echo "Building dotfiles CI test image..."
      docker build --network host -f "$DOTFILES_DIR/Dockerfile.test" -t dotfiles-test "$DOTFILES_DIR"
    fi
    ;;
  update)
    source "$DOTFILES_DIR/scripts/lib/ui.sh"
    ui_log_init

    banner "Dotfiles Update" "$(hostname) · $(date +%Y-%m-%d)"

    step "Pull latest changes" git -C "$DOTFILES_DIR" pull --rebase --autostash

    if command -v brew &>/dev/null; then
      step "Homebrew update" brew update
      step "Brew bundle" brew bundle --file="$DOTFILES_DIR/Brewfile"
      step "Brew cleanup" brew cleanup -s
    fi

    if command -v mise &>/dev/null; then
      export MISE_GLOBAL_CONFIG_FILE="$DOTFILES_DIR/.mise.toml"
      step "Runtime update (mise)" mise install --yes
    fi

    step "Re-link symlinks" bash "$DOTFILES_DIR/scripts/setup/symlinks.sh"

    echo
    ui_success "Dotfiles updated"
    ;;
  doctor)
    bash "$DOTFILES_DIR/scripts/doctor.sh"
    ;;
  edit)
    cd "$DOTFILES_DIR" && ${EDITOR:-vim} .
    ;;
  *)
    echo "Usage: dotfiles {test|update|doctor|edit}"
    echo
    echo "  test           Build and run Docker CI test (automated)"
    echo "  test -i        Build and launch interactive container (see Gum UI)"
    echo "  update         Pull latest, brew bundle, mise install, re-link"
    echo "  doctor         Run post-install validation checks"
    echo "  edit           Open dotfiles directory in \$EDITOR"
    exit 1
    ;;
esac
