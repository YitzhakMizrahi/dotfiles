#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$HOME/.dotfiles"
CONTAINER="bootstrap-test"
USER="devuser"

case "${1:-}" in
  build)
    go build -o build/bin/bootstrap-cli main.go
    ;;
  exec)
    lxc exec "$CONTAINER" -- su - "$USER"
    ;;
  push)
    lxc file push build/bin/bootstrap-cli "$CONTAINER/home/$USER/bootstrap-cli" --mode=755
    ;;
  run)
    shift
    lxc exec "$CONTAINER" -- su - "$USER" -c "cd /home/$USER && ./bootstrap-cli $*"
    ;;
  restore)
    lxc restore "$CONTAINER" clean-setup
    ;;
  test)
    echo "Restoring clean snapshot..."
    lxc restore "$CONTAINER" clean-setup

    echo "Pushing dotfiles to container..."
    lxc file push -r "$DOTFILES_DIR" "$CONTAINER/home/$USER/" --uid 1000 --gid 1000

    echo "Running install..."
    lxc exec "$CONTAINER" -- su - "$USER" -c "cd .dotfiles && bash scripts/install.sh <<< 'n'"

    echo "Running validation..."
    lxc exec "$CONTAINER" -- su - "$USER" -c "bash .dotfiles/scripts/test-validate.sh"
    ;;
  *)
    echo "Usage: lxc-dev {build|exec|push|run [args...]|restore|test}"
    exit 1
    ;;
esac
