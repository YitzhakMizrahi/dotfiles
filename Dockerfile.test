# ╭────────────────────────────────────────────────────────────╮
# │              Dotfiles Install Test                         │
# ╰────────────────────────────────────────────────────────────╯
# Usage: docker build -f Dockerfile.test -t dotfiles-test .
#
# Simulates a fresh Ubuntu machine, runs the full install,
# then validates everything is set up correctly.

FROM ubuntu:22.04

# Avoid interactive prompts during apt installs
ENV DEBIAN_FRONTEND=noninteractive

# Install minimal prerequisites (what a fresh machine has)
RUN apt-get update && apt-get install -y \
    sudo \
    curl \
    git \
    ca-certificates \
    locales \
    && rm -rf /var/lib/apt/lists/* \
    && locale-gen en_US.UTF-8

ENV LANG=en_US.UTF-8

# Create non-root user (install.sh refuses to run as root)
RUN useradd -m -s /bin/bash devuser \
    && echo "devuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER devuser
WORKDIR /home/devuser

# Copy dotfiles into the container
COPY --chown=devuser:devuser . /home/devuser/.dotfiles

# Run the installer (non-interactive)
RUN cd /home/devuser/.dotfiles \
    && bash scripts/install.sh <<< "n"

# Run validation tests
RUN bash /home/devuser/.dotfiles/scripts/test-validate.sh
