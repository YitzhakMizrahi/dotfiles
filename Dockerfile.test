# ╭────────────────────────────────────────────────────────────╮
# │              Dotfiles Install Test                         │
# ╰────────────────────────────────────────────────────────────╯
#
# CI mode (automated):
#   docker build --network host -f Dockerfile.test -t dotfiles-test .
#
# Interactive mode (see Gum UI, prompts, etc.):
#   docker build --network host -f Dockerfile.test --target ready -t dotfiles-ready .
#   docker run -it --network host dotfiles-ready bash scripts/install.sh

FROM ubuntu:22.04 AS base

# Avoid interactive prompts during apt installs
ENV DEBIAN_FRONTEND=noninteractive

# Install minimal prerequisites (what a fresh machine has)
RUN apt-get update && apt-get install -y \
    sudo \
    curl \
    git \
    ca-certificates \
    locales \
    && rm -rf /var/lib/apt/lists/* \
    && locale-gen en_US.UTF-8

ENV LANG=en_US.UTF-8

# Create non-root user with password (mirrors a real machine)
RUN useradd -m -s /bin/bash devuser \
    && echo "devuser:devuser" | chpasswd \
    && usermod -aG sudo devuser

USER devuser
WORKDIR /home/devuser

# Copy dotfiles into the container
COPY --chown=devuser:devuser . /home/devuser/.dotfiles

# ── Interactive target ────────────────────────────────────────
# Stops here — shell in and run install.sh yourself to see full UI
FROM base AS ready
CMD ["bash"]

# ── CI target (default) ──────────────────────────────────────
FROM base AS ci
ENV DOTFILES_CI=1
RUN cd /home/devuser/.dotfiles \
    && bash scripts/install.sh

# Run validation tests
RUN bash /home/devuser/.dotfiles/scripts/test/validate.sh
